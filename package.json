{
  "name": "pi-setup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "check": "pnpm fmt-check && pnpm lint && pnpm typecheck && pnpm test",
    "fmt": "biome format --write .",
    "fmt-check": "biome format .",
    "lint": "biome check .",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "extensions"
    ],
    "skills": [
      "skills"
    ],
    "prompts": [
      "prompts"
    ],
    "themes": [
      "themes"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
